---
import {
  ArrowDown,
  ArrowUp,
  ChevronDown,
  ChevronLeft,
  ChevronRight,
  CornerDownLeft,
  Folder,
  Menu,
  Paperclip,
  Play,
  Plus,
  RefreshCw,
  SendHorizontal,
  Settings,
  Square,
  Trash2,
  X,
} from "@lucide/astro";
import WorkspaceFileTree from "./components/WorkspaceFileTree";
import { escapeHtml, renderAnsiBody, renderBannerBody, renderPiBody } from "./lib/renderers";
import { SETTINGS_FIELDS as settingsFields } from "./pi-app/workspace/settings-schema";

const {
  initialRoute = "workspace",
  initialSession = "active",
  treeOpen = false,
  sidebarCollapsed = false,
  showCompaction = false,
  showDisconnect = false,
  scanlines = false,
  showUpdateRelease = false,
  showUpdateTip = false,
  workspaces = [],
  fileTree = [],
  conversation = [],
  slashCommands = [],
} = Astro.props;

const activeWorkspace = workspaces[0];
const activeSession = activeWorkspace?.sessions?.[0];
const activeWorkspaceName = activeWorkspace?.name || "workspace";
const activeSessionTitle = activeSession?.title || "no session";
const activeSessionID = activeSession?.id || "";
const activeWorkspaceID = activeWorkspace?.id || "";
const workspaceVisible = initialRoute !== "picker";
const pickerVisible = initialRoute === "picker";
const emptyVisible = initialSession === "empty";
const sessionVisible = !emptyVisible;
const bodyClass = ["app-body", treeOpen && "with-tree", treeOpen && "tree-open"].filter(Boolean).join(" ");
const bodyGrid = sidebarCollapsed ? (treeOpen ? "1fr 260px" : "1fr") : (treeOpen ? "280px 1fr 260px" : "280px 1fr");
const pickerHidden = !pickerVisible;
const workspaceHidden = !workspaceVisible;
const sessionHidden = !sessionVisible;
const emptyHidden = !emptyVisible;
const compactionHidden = !showCompaction;
const treeHidden = !treeOpen;
const statusColor = showDisconnect ? "var(--danger)" : "var(--fg-3)";
const statusTitle = showDisconnect ? "disconnected" : "connecting";

function toolStatus(msg) {
  if (msg.status === "running") return `<span class="spinner">⠋</span><span style="color:var(--accent)">running</span>`;
  if (msg.status === "err") return `<span class="err">✗</span>${escapeHtml(msg.resultMeta || "failed")}`;
  return `<span class="ok">✓</span>${msg.durationMs ? `${msg.durationMs} ms` : ""}${msg.resultMeta ? ` · ${escapeHtml(msg.resultMeta)}` : ""}`;
}

function isToolCollapsed(msg) {
  return msg.collapsedByDefault !== false;
}

---

<pi-app class="app" data-route={initialRoute} data-tree={treeOpen ? "on" : "off"} data-sidebar={sidebarCollapsed ? "collapsed" : "open"} data-session={initialSession} data-active-session-id={activeSessionID} data-active-workspace-id={activeWorkspaceID}>
  <header class="topbar">
    <button class="sb-expand-btn" type="button" data-action="expand-sidebar" aria-label="show sidebar" style={sidebarCollapsed ? "display:inline-flex" : "display:none"}><ChevronRight size={16} strokeWidth={1.75} aria-hidden="true" /></button>
    <button class="hamburger" type="button" data-action="open-drawer" aria-label="open sidebar"><Menu size={16} strokeWidth={1.75} aria-hidden="true" /></button>
    <span class="brand" aria-label="pi.dev / web">
      <span class="pi">pi.dev</span><span class="slash">/</span><span class="web">web</span><span class="cursor-block"></span>
    </span>
    <span class="crumb">
      <span class="sep">/</span><span class="ws" data-active-workspace>{activeWorkspaceName}</span>
      <span class="sep">/</span><span class="session" data-active-session-title title={`${activeSessionTitle} · ${activeSessionID}`}>{activeSessionTitle}</span>
    </span>
    <div class="actions">
      <button class:list={["iconbtn", treeOpen && "on"]} type="button" data-action="toggle-tree" aria-label="toggle file tree" title="files" hidden={workspaceHidden}>
        <Folder size={14} strokeWidth={1.5} aria-hidden="true" />
      </button>
      <span class="iconbtn statusbtn" style={`color:${statusColor}`} title={statusTitle}>●</span>
    </div>
  </header>

  <section class="picker-shell" data-view="picker" hidden={pickerHidden}> 
    <div class="picker-inner">
      <div class="picker-header-row">
        <p class="picker-tag"><span class="accent">pi.dev</span> &mdash; open a folder to start a session. No login.</p>
        <button class="cancel-btn" type="button" data-action="route-workspace">cancel</button>
      </div>
      <div class="picker-card">
        <div class="card-head"><span class="left">open a folder</span></div>
        <form class="input-row" data-path-form>
          <input name="path" placeholder="~/code/my-project   or   /Users/me/Code/project" autocomplete="off" />
          <button class="open-btn" type="submit" aria-label="open typed path">open <CornerDownLeft size={12} strokeWidth={1.75} aria-hidden="true" /></button>
        </form>
        <div style="padding:0 16px 12px;font-size:11px;color:var(--fg-3)">paste a path, pick from <code>~</code>, or drop a folder onto the window.</div>
        <div class="folder-browser" data-folder-browser>
          <div class="folder-browser-head"><button type="button" data-action="folder-up"><ArrowUp size={12} strokeWidth={1.75} aria-hidden="true" /> up</button><span data-folder-path>~</span><button type="button" data-action="folder-open-current">open this folder</button></div>
          <div class="folder-list" data-folder-list></div>
        </div>
        <form class="clone-row" data-clone-form>
          <input name="gitUrl" placeholder="git clone URL" autocomplete="off" />
          <input name="name" placeholder="folder name (optional)" autocomplete="off" />
          <button type="submit">clone & open</button>
        </form>
      </div>
      <div class="picker-card" data-recent-workspaces>
        <div class="card-head"><span class="left">recent workspaces</span><span class="right" data-workspace-count>{workspaces.length} known</span></div>
        {workspaces.slice(0, 4).map((workspace) => (
          <button class="recent-row" type="button" data-workspace={workspace.id} aria-label={`open ${workspace.name}`}>
            <span class="glyph"><ChevronRight size={12} strokeWidth={1.75} aria-hidden="true" /></span>
            <span class="ws-info"><span class="name">{workspace.name}</span><span class="path">{workspace.path}</span></span>
            <span class="ws-stat">{workspace.live ? <><span class="live">● live</span><span class="lbl">{workspace.sessionCount} sessions</span></> : <><span>{workspace.lastUsed}</span><span class="lbl">{workspace.sessionCount} sessions</span></>}</span>
            <span class="open-cta">open <CornerDownLeft size={12} strokeWidth={1.75} aria-hidden="true" /></span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class={bodyClass} data-view="workspace" hidden={workspaceHidden} style={`grid-template-columns:${bodyGrid}`}> 
    <div class="sidebar-wrap" hidden={sidebarCollapsed}>
      <aside class="sidebar" aria-label="workspaces and sessions">
        <div class="sb-section" style="flex:1;overflow-y:auto;min-height:0">
          <div class="sb-head"><span>workspaces</span><span class="sb-head-actions"><button class="add" type="button" data-action="route-picker"><Plus size={12} strokeWidth={1.75} aria-hidden="true" /> open</button><button class="refresh" type="button" data-action="refresh-workspaces" title="refresh workspaces" aria-label="refresh workspaces"><RefreshCw size={12} strokeWidth={1.75} aria-hidden="true" /></button><button class="sb-collapse" type="button" data-action="collapse-sidebar" title="collapse sidebar" aria-label="collapse sidebar"><ChevronLeft size={14} strokeWidth={1.75} aria-hidden="true" /></button></span></div>
          {workspaces.map((workspace) => {
            const isActiveWorkspace = workspace.id === activeWorkspaceID;
            return (
              <div class="workspace-group" data-workspace-group={workspace.id}>
                <button type="button" class:list={["ws-row", isActiveWorkspace && "open"]} data-action="toggle-workspace" data-workspace={workspace.id} aria-expanded={isActiveWorkspace ? "true" : "false"}>
                  <span class="ws-stack"><span class="ws-name"><span class:list={["dot", workspace.live && "live"]}></span><span class="label">{workspace.name}</span></span><span class="ws-path">{workspace.path}</span></span>
                  <span class="ws-meta">{workspace.sessionCount}</span>
                </button>
                <div class="sessions" hidden={!isActiveWorkspace}>
                  {(workspace.sessions || []).map((session) => (
                    <button type="button" class:list={[
                      "session-row",
                      isActiveWorkspace && session.id === activeSessionID && "selected",
                      (session.active || session.live) && "active",
                    ]} data-session={session.id} data-workspace={workspace.id} data-title={session.title}>
                      <span class="title">{session.title}</span><span class:list={["meta", (session.active || session.live) && "live"]} hidden={!(session.active || session.live)}>{session.active || session.live ? "waiting" : ""}</span>
                    </button>
                  ))}
                  {(workspace.sessions || []).length === 0 && <div style="padding:12px 16px;color:var(--fg-3);font-size:12px;font-style:italic">no sessions yet · press N to start one</div>}
                  {(workspace.sessions || []).length > 0 && <button type="button" class="session-row clear-sessions-row" data-action="delete-workspace-sessions" data-workspace={workspace.id}><span class="title"><Trash2 size={12} strokeWidth={1.75} aria-hidden="true" /> delete all sessions</span></button>}
                  <button type="button" class="session-row new-session-row" data-action="new-session" data-workspace={workspace.id}><span class="title"><Plus size={12} strokeWidth={1.75} aria-hidden="true" /> new session</span></button>
                </div>
              </div>
            );
          })}
        </div>
        <div class="sb-footer">
          <button class="update-release" type="button" data-action="show-update-tip" hidden={!showUpdateRelease}>New Version Released!</button>
          <span class="update-tip" data-update-tip hidden={!showUpdateTip}>Run <code>pi-web update</code>, then restart pi-web.</span>
          <div class="sb-footer-status">
            <span class="status-dot"></span><span>connecting</span>
            <button class="sb-settings" type="button" data-action="open-settings" title="settings" aria-label="open settings"><Settings size={14} strokeWidth={1.75} aria-hidden="true" /></button>
          </div>
        </div>
      </aside>
      <div class="sb-resizer" role="separator" aria-orientation="vertical" aria-label="resize sidebar" title="drag to resize"></div>
    </div>

    <main class="main" data-main="session" hidden={sessionHidden}> 
      {showDisconnect && <div class="disconn"><span class="pulse"></span><span>disconnected · retrying in 2s</span></div>}
      <form class="shell-row" data-shell-form>
        <span class="shell-prefix">$</span>
        <input name="command" placeholder="run shell command in workspace" autocomplete="off" />
        <button type="submit" aria-label="run shell command" title="run shell command"><Play size={14} strokeWidth={2} aria-hidden="true" /></button>
      </form>
      <div class:list={["term", scanlines && "scanlines"]}>
        <div class="term-inner">
          {conversation.length === 0 ? (
            <div class="msg"><div class="prefix pi">pi &gt;</div><div class="body">connecting to local backend…</div></div>
          ) : conversation.map((msg) => (
            msg.kind === "banner" ? <pre class="ascii-banner" set:html={renderBannerBody(msg.text)}></pre> :
            msg.kind === "user" ? <div class="msg"><div class="prefix user">you &gt;</div><div class="body">{msg.text}</div></div> :
            msg.kind === "think" ? <div class="msg"><div class="prefix think">…</div><div class="body" style="flex:1"><div class="thinking-block"><span class="label">thinking</span>{msg.text}</div></div></div> :
            msg.kind === "pi" ? <div class="msg"><div class="prefix pi">pi &gt;</div><div class="body" set:html={renderPiBody(msg.text)}></div></div> :
            msg.kind === "tool" ? <div class:list={["tool-card", isToolCollapsed(msg) && "collapsed"]} data-tool={msg.tool}>
              <button type="button" class="tc-head" aria-expanded={isToolCollapsed(msg) ? "false" : "true"} data-action="toggle-tool">
                <span class="tc-glyph">●</span><span class="tc-name">{msg.tool}</span><span class="tc-args">{msg.args}</span><span class="tc-meta" set:html={toolStatus(msg)}></span><span class="tc-caret">{isToolCollapsed(msg) ? <ChevronRight size={12} strokeWidth={1.75} aria-hidden="true" /> : <ChevronDown size={12} strokeWidth={1.75} aria-hidden="true" />}</span>
              </button>
              {msg.body && <div class="tc-body" hidden={isToolCollapsed(msg)} set:html={renderAnsiBody(msg.body)}></div>}
            </div> : null
          ))}
          <div class="compaction" hidden={compactionHidden}><span class="lbl">⚠ context summarized</span><span>older messages summarized · /undo to revert</span></div>
        </div>
      </div>
      <button type="button" class="scroll-bottom-btn" data-action="scroll-bottom" aria-label="scroll to bottom" title="scroll to bottom" hidden><ArrowDown size={14} strokeWidth={1.75} aria-hidden="true" /></button>
    </main>

    <main class="main" data-main="empty" hidden={emptyHidden}> 
      <div class="empty-shell"><div class="empty-inner"><div class="empty-title">new session in <span class="accent" data-empty-workspace>{activeWorkspaceName}</span></div><div class="empty-sub">pi is idle. say the first thing.</div><div class="empty-tips"><div class="dim">session id will be assigned on first send.</div></div></div></div>
    </main>

    <aside class="tree" aria-label="file tree" hidden={treeHidden}> 
      <div class="tree-head"><span>files</span><span class="tree-head-actions"><span class="branch" data-git-status>—</span><button type="button" data-action="refresh-tree" aria-label="refresh file tree" title="refresh file tree"><RefreshCw size={12} strokeWidth={1.75} aria-hidden="true" /></button></span></div>
      <div class="tree-list">
        <WorkspaceFileTree client:load initialFiles={fileTree} />
      </div>
    </aside>
    <div class="file-preview-modal" data-file-preview hidden>
      <div class="fp-dialog" role="dialog" aria-modal="true" aria-labelledby="file-preview-title">
        <div class="fp-head">
          <div><strong id="file-preview-title" class="fp-path">file</strong><small></small></div>
          <div class="fp-actions"><button type="button" data-action="save-file-preview" hidden>save</button><button type="button" data-action="toggle-file-preview-mode" hidden>text</button><button type="button" data-action="close-file-preview" aria-label="close file preview"><X size={14} strokeWidth={1.75} aria-hidden="true" /></button></div>
        </div>
        <div class="fp-body"></div>
      </div>
    </div>
  <div class="prompt-region">
    <div class="slash-pop" hidden>
      <div class="slash-head">slash commands · type to filter</div>
      <div class="slash-list">{slashCommands.map((cmd, index) => {
        const command = cmd.command || cmd.cmd || `/${cmd.name}`;
        return <button type="button" class:list={["slash-item", index === 0 && "selected"]} data-slash={command}><span class="sl-cmd">{command}</span><span class="sl-tags"><span class="sl-scope">{cmd.scope || "global"}</span><span class="sl-source">{cmd.source || "command"}</span></span><span class="sl-desc">{cmd.description || cmd.desc}</span></button>;
      })}</div>
    </div>
    <div class="prompt-bar">
      <button class="attach-btn" type="button" aria-label="attach files" title="attach files"><Paperclip size={14} strokeWidth={1.5} aria-hidden="true" /></button>
      <input type="file" multiple hidden data-file-input />
      <div class="prompt-input-col"><div class="attach-chips" hidden></div><textarea class="prompt-textarea" placeholder="ask pi to do something…" rows="1"></textarea></div>
      <div class="prompt-actions"><button class="stop-btn" type="button" aria-label="stop" title="stop" hidden><Square size={13} strokeWidth={2} aria-hidden="true" /></button><button class="send-btn" type="button" aria-label="send" title="send" disabled><SendHorizontal size={14} strokeWidth={2} aria-hidden="true" /></button></div>
      <div class="drop-overlay" hidden><span>drop to attach</span></div>
    </div>
    <div class="prompt-meta" data-prompt-meta>— |  —</div>
  </div>

    <div class="scrim" data-action="close-drawer"></div>
  </section>



  <div class="settings-modal" data-settings-modal hidden>
    <form class="settings-dialog" data-settings-form>
      <div class="settings-head">
        <div><strong>pi settings</strong><small>same files used by <code>/settings</code></small></div>
        <button type="button" data-action="close-settings" aria-label="close settings"><X size={14} strokeWidth={1.75} aria-hidden="true" /></button>
      </div>
      <div class="settings-toolbar">
        <label>scope
          <select name="scope" data-settings-scope>
            <option value="project">project</option>
            <option value="global">global</option>
          </select>
        </label>
        <span data-settings-path>—</span>
      </div>
      <div class="settings-grid">
        {settingsFields.map((field) => (
          <label class="settings-field">
            <span>{field.label}</span>
            {field.type === "text" ? (
              <input data-setting={field.path} autocomplete="off" placeholder={field.hint} />
            ) : field.type === "boolean" ? (
              <select data-setting={field.path}>
                <option value="inherit">inherit</option>
                <option value="true">on</option>
                <option value="false">off</option>
              </select>
            ) : (
              <select data-setting={field.path}>
                <option value="inherit">inherit</option>
                {field.values.map((value) => <option value={value}>{value}</option>)}
              </select>
            )}
            <small>effective: not set</small>
          </label>
        ))}
      </div>
      <div class="settings-foot">
        <span data-settings-status>blank fields inherit from effective settings</span>
        <button type="button" data-action="close-settings">cancel</button>
        <button type="submit">save</button>
      </div>
    </form>
  </div>

  <div class="twk-panel" data-tweaks hidden><div class="twk-hd"><b>Tweaks</b><button class="twk-x" type="button" data-action="close-tweaks" aria-label="Close tweaks"><X size={14} strokeWidth={1.75} aria-hidden="true" /></button></div><div class="twk-body"><div class="twk-sect">Layout</div><button class="twk-btn secondary" type="button" data-action="route-picker">workspace picker</button><button class="twk-btn secondary" type="button" data-action="route-workspace">session view</button><button class="twk-btn secondary" type="button" data-action="new-session">new session</button></div></div>
</pi-app>

<script>
  import "./pi-app/index";
</script>
