---
import AppIcon from "./shared/icons/AppIcon.astro";
import { UI_LOCALES } from "./i18n/locales";
import { SETTINGS_FIELDS as settingsFields } from "./pi-app/settings/settings-schema";
const { workspaces = [] } = Astro.props;
const modelFields = settingsFields.filter((field) => ["defaultProvider", "defaultModel", "defaultThinkingLevel"].includes(field.path));
---

<pi-app class="app" data-initial-workspaces={JSON.stringify(workspaces)}>
  <header class="topbar">
    <span class="brand" aria-label="pi.dev / web"><span class="pi">pi.dev</span><span class="slash">/</span><span class="web">web</span><span class="cursor-block"></span></span>
    <span class="crumb"><span class="sep">/</span><span class="ws" data-active-workspace>plugins</span></span>
    <div class="actions" data-plugin-toolbar>
      <button class="iconbtn" type="button" data-action="open-settings" title="settings" aria-label="open settings"><AppIcon name="settings" size={14} strokeWidth={1.75} /></button>
    </div>
  </header>

  <section class="app-body" data-view="workspace">
    <main class="main" data-main></main>
  </section>

  <div class="settings-modal" data-settings-modal hidden>
    <form class="settings-dialog" data-settings-form role="dialog" aria-modal="true" aria-labelledby="settings-title" tabindex="-1">
      <div class="settings-head">
        <div><strong id="settings-title" data-i18n="settingsTitle">pi settings</strong><small data-i18n="settingsSubtitle">pi-web settings only</small></div>
        <button type="button" data-action="close-settings" aria-label="close settings" data-i18n-aria-label="closeSettings"><AppIcon name="x" size={14} strokeWidth={1.75} /></button>
      </div>
      <div class="settings-body">
        <div class="settings-language-row">
          <label><span data-i18n="language">Language</span><select name="uiLanguage" data-ui-language>{UI_LOCALES.map((locale) => <option value={locale.code}>{locale.label}</option>)}</select></label>
          <small data-i18n="languageHint">Changes apply immediately and are saved on this device.</small>
        </div>
        <div class="settings-toolbar">
          <label><span data-i18n="scope">scope</span><select name="scope" data-settings-scope><option value="project" data-i18n="project">project</option><option value="global" data-i18n="global">global</option></select></label>
          <span data-settings-path>—</span>
        </div>
        <details class="auth-login" data-auth-form>
          <summary><span class="auth-login-title"><span data-i18n="authTitle">Authentication</span> <em data-i18n="authMode">API key login</em></span><small data-auth-status>API key is stored in ~/.pi/agent/auth.json</small></summary>
          <div class="auth-login-fields">
            <label><span data-i18n="provider">provider</span><select data-auth-provider><option value="">loading providers…</option></select></label>
            <label><span data-i18n="apiKey">API key</span><input data-auth-api-key type="password" autocomplete="off" placeholder="paste API key" data-i18n-placeholder="pasteApiKey" /></label>
            <div class="auth-login-actions"><button type="button" data-action="save-auth-provider" data-i18n="saveKey">save key</button><button type="button" data-action="logout-auth-provider" data-i18n="logout">logout</button></div>
          </div>
          <div class="oauth-login-fields">
            <label><span data-i18n="oauthProvider">OAuth provider</span><select data-oauth-provider><option value="" data-i18n="loadingOAuthProviders">loading OAuth providers…</option></select></label>
            <div class="auth-login-actions"><button type="button" data-action="start-oauth-login" data-i18n="loginWithOAuth">login with OAuth</button><button type="button" data-action="logout-oauth-provider" data-i18n="logout">logout</button></div>
            <a data-oauth-link href="#" target="_blank" rel="noreferrer" hidden data-i18n="openLoginPage">open login page</a>
            <input data-oauth-input autocomplete="off" placeholder="prompt input or redirect URL" data-i18n-placeholder="oauthInput" hidden />
            <button type="button" data-action="send-oauth-input" hidden data-i18n="send">send</button>
            <small data-oauth-status>OAuth supports Claude, Codex, and Copilot subscriptions.</small>
          </div>
        </details>
        <details class="plugin-settings" data-plugin-settings open>
          <summary><span class="auth-login-title">Plugins <em>local JavaScript</em></span><small>Install a local folder containing plugin.json and an entry module.</small></summary>
          <div class="plugin-install-row">
            <select data-plugin-source aria-label="plugin source"><option value="github">GitHub</option><option value="local">local path</option></select>
            <input data-plugin-path autocomplete="off" placeholder="/Users/me/dev/pi-web-plugin or owner/repo" />
            <button type="button" data-action="install-plugin">install</button><button type="button" data-action="check-plugin-updates">check updates</button><button type="button" data-action="reload-plugins">reinstall GitHub</button>
          </div>
          <div class="plugin-list" data-plugin-list>No plugins installed.</div>
        </details>
        <div class="plugin-settings-root" data-plugin-settings-root></div>
        <section class="settings-group">
          <div class="settings-group-head"><div><strong data-i18n="model">Model</strong><small data-i18n="modelDescription">provider, model, thinking</small></div></div>
          <div class="settings-grid">
            {modelFields.map((field) => (
              <label class="settings-field">
                <span>{field.label}</span>
                {field.type === "providerSelect" || field.type === "modelSelect" ? <><select data-setting={field.path} disabled><option value="inherit">loading models…</option></select><input data-custom-setting={field.path} autocomplete="off" placeholder={`custom ${field.label}`} hidden /></> : <select data-setting={field.path}><option value="inherit">inherit</option>{field.values?.map((value) => <option value={value}>{value}</option>)}</select>}
                <small>effective: not set</small>
              </label>
            ))}
          </div>
        </section>
      </div>
      <div class="settings-foot"><span data-settings-status>open a workspace to edit project settings</span><button type="submit" data-i18n="save">save</button></div>
    </form>
  </div>
</pi-app>

<script>
  window.addEventListener("DOMContentLoaded", () => {
    void import("./pi-app/index");
  }, { once: true });
</script>
