---
type IconName = "arrow-up" | "chevron-right" | "corner-down-left" | "menu" | "settings" | "x";
type Props = { name: IconName; size?: number; strokeWidth?: number; class?: string; ariaHidden?: boolean };

const { name, size = 16, strokeWidth = 1.75, class: className, ariaHidden = true } = Astro.props as Props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={ariaHidden ? "true" : undefined}
  class={className}
>
  {name === "arrow-up" && <path d="m5 12 7-7 7 7"></path>}
  {name === "arrow-up" && <path d="M12 19V5"></path>}
  {name === "chevron-right" && <path d="m9 18 6-6-6-6"></path>}
  {name === "corner-down-left" && <path d="M9 10 4 15l5 5"></path>}
  {name === "corner-down-left" && <path d="M20 4v7a4 4 0 0 1-4 4H4"></path>}
  {name === "menu" && <path d="M4 5h16"></path>}
  {name === "menu" && <path d="M4 12h16"></path>}
  {name === "menu" && <path d="M4 19h16"></path>}
  {name === "settings" && <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path>}
  {name === "settings" && <circle cx="12" cy="12" r="3"></circle>}
  {name === "x" && <path d="M18 6 6 18"></path>}
  {name === "x" && <path d="m6 6 12 12"></path>}
</svg>
