---
type IconName = "arrow-up" | "chevron-right" | "corner-down-left" | "menu" | "settings" | "x";
type Props = { name: IconName; size?: number; strokeWidth?: number; class?: string; ariaHidden?: boolean };

const { name, size = 16, strokeWidth = 1.75, class: className, ariaHidden = true } = Astro.props as Props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={ariaHidden ? "true" : undefined}
  class={className}
>
  {name === "arrow-up" && <path d="m5 12 7-7 7 7"></path>}
  {name === "arrow-up" && <path d="M12 19V5"></path>}
  {name === "chevron-right" && <path d="m9 18 6-6-6-6"></path>}
  {name === "corner-down-left" && <path d="M9 10 4 15l5 5"></path>}
  {name === "corner-down-left" && <path d="M20 4v7a4 4 0 0 1-4 4H4"></path>}
  {name === "menu" && <path d="M4 5h16"></path>}
  {name === "menu" && <path d="M4 12h16"></path>}
  {name === "menu" && <path d="M4 19h16"></path>}
  {name === "settings" && <path d="M12 15.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z"></path>}
  {name === "settings" && <path d="M19.4 15a1.7 1.7 0 0 0 .34 1.88l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06A1.7 1.7 0 0 0 15 19.4a1.7 1.7 0 0 0-1 .6l-.08.08a2 2 0 0 1-3.84-1.41v-.08A1.7 1.7 0 0 0 9 17.1a1.7 1.7 0 0 0-1.88.34l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.7 1.7 0 0 0 4.6 13a1.7 1.7 0 0 0-.6-1l-.08-.08a2 2 0 0 1 1.41-3.84h.08A1.7 1.7 0 0 0 6.9 7a1.7 1.7 0 0 0-.34-1.88l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.7 1.7 0 0 0 11 2.6a1.7 1.7 0 0 0 1-.6l.08-.08a2 2 0 0 1 3.84 1.41v.08A1.7 1.7 0 0 0 17.1 5a1.7 1.7 0 0 0 1.88-.34l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.7 1.7 0 0 0 19.4 9c.3.37.5.82.6 1.3h.08a2 2 0 0 1 1.41 3.84l-.08.08a1.7 1.7 0 0 0-.6 1Z"></path>}
  {name === "x" && <path d="M18 6 6 18"></path>}
  {name === "x" && <path d="m6 6 12 12"></path>}
</svg>
