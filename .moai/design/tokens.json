{
  "color": {
    "background": {
      "base": {
        "$type": "color",
        "$value": "#000000"
      },
      "surface": {
        "$type": "color",
        "$value": "#0a0a0a"
      },
      "raised": {
        "$type": "color",
        "$value": "#111111"
      }
    },
    "foreground": {
      "strong": {
        "$type": "color",
        "$value": "#f5f5f5"
      },
      "body": {
        "$type": "color",
        "$value": "#d4d4d4"
      },
      "muted": {
        "$type": "color",
        "$value": "#8b8b8b"
      }
    },
    "accent": {
      "primary": {
        "$type": "color",
        "$value": "#00ff88"
      },
      "amber": {
        "$type": "color",
        "$value": "#ffb86c"
      },
      "cyan": {
        "$type": "color",
        "$value": "#5af2ff"
      },
      "danger": {
        "$type": "color",
        "$value": "#ff6b6b"
      }
    }
  },
  "fontFamily": {
    "mono": {
      "$type": "fontFamily",
      "$value": [
        "JetBrains Mono",
        "Monaspace Neon",
        "SF Mono",
        "Cascadia Code",
        "Fira Code",
        "Menlo",
        "Consolas",
        "ui-monospace",
        "monospace"
      ]
    }
  },
  "dimension": {
    "space": {
      "1": {
        "$type": "dimension",
        "$value": "4px"
      },
      "2": {
        "$type": "dimension",
        "$value": "8px"
      },
      "3": {
        "$type": "dimension",
        "$value": "12px"
      },
      "4": {
        "$type": "dimension",
        "$value": "16px"
      },
      "6": {
        "$type": "dimension",
        "$value": "24px"
      },
      "8": {
        "$type": "dimension",
        "$value": "32px"
      },
      "12": {
        "$type": "dimension",
        "$value": "48px"
      },
      "16": {
        "$type": "dimension",
        "$value": "64px"
      }
    }
  },
  "duration": {
    "fast": {
      "$type": "duration",
      "$value": "140ms"
    },
    "base": {
      "$type": "duration",
      "$value": "200ms"
    }
  },
  "cubicBezier": {
    "out": {
      "$type": "cubicBezier",
      "$value": [
        0.16,
        1,
        0.3,
        1
      ]
    }
