{
  "name": "@epsilondelta-ai/pi-web",
  "version": "1.19.1",
  "private": false,
  "description": "Browser UI for operating the local pi coding agent.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pi-web": "bin/pi-web.js"
  },
  "files": [
    "bin/pi-web.js",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "build": "astro build",
    "embed:assets": "find static -mindepth 1 ! -name README.txt -exec rm -rf {} + && cp -R dist/. static/",
    "build:binary": "bun run build && bun run embed:assets && go build -ldflags \"-X main.version=v$(node -p 'require(\"./package.json\").version')\" -o dist/pi-web .",
    "build:single": "bun run build:binary",
    "preview": "astro preview --host 0.0.0.0",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "backend": "go run .",
    "backend:mock": "go run . --mock",
    "backend:test": "go test $(go list ./... | grep -v '/node_modules/')",
    "backend:test:coverage": "go test $(go list ./... | grep -v '/node_modules/') -coverprofile=/tmp/piweb-cover.out -covermode=count >/tmp/piweb-go-test.log && go tool cover -func=/tmp/piweb-cover.out | tail -1 | grep '100.0%'",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "measure:startup": "bun run build && node scripts/measure-startup.mjs",
    "measure:startup:mobile": "bun run build && PI_WEB_THROTTLE=mobile PI_WEB_BUDGET_FCP=1500 PI_WEB_BUDGET_DCL=2500 PI_WEB_BUDGET_LOAD=3000 node scripts/measure-startup.mjs",
    "measure:user-flow": "bun run build && node scripts/measure-user-flow.mjs",
    "check:perf": "bun run measure:startup && bun run measure:startup:mobile && bun run measure:user-flow",
    "check": "bun run lint && bun run typecheck && bun run test && bun run backend:test && bun run build && bun run build-storybook"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.53",
    "@astrojs/react": "^5.0.5",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lucide/astro": "^1.16.0",
    "astro": "6.3.3",
    "browser-whisper": "^1.0.2",
    "markdown-it": "^14.1.1",
    "material-icon-theme": "5.35.0",
    "notyf": "^3.10.0",
    "react": "^19.2.6",
    "react-arborist": "^3.7.0",
    "react-dom": "^19.2.6",
    "shiki": "4.0.2",
    "virtual-scroller": "^1.16.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook-astro/framework": "1.2.0",
    "@storybook/addon-docs": "10.4.0",
    "@storybook/builder-vite": "10.4.0",
    "@testing-library/jest-dom": "6.9.1",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "4.1.6",
    "eslint": "^10.4.0",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "jsdom": "29.1.1",
    "lighthouse": "^13.3.0",
    "puppeteer-core": "^25.1.0",
    "storybook": "10.4.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "4.1.6"
  }
}
