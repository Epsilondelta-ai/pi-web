{
  "name": "pi-web-ui",
  "version": "1.2.4",
  "private": true,
  "description": "Astro prototype for operating pi from a browser.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "build": "astro build",
    "embed:assets": "find backend/cmd/pi-web-server/static -mindepth 1 ! -name README.txt -exec rm -rf {} + && cp -R dist/. backend/cmd/pi-web-server/static/",
    "build:binary": "bun run build && bun run embed:assets && go build -ldflags \"-X main.version=v$(node -p 'require(\"./package.json\").version')\" -o dist/pi-web ./backend/cmd/pi-web-server",
    "build:single": "bun run build:binary",
    "preview": "astro preview --host 0.0.0.0",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "backend": "go run ./backend/cmd/pi-web-server",
    "backend:mock": "go run ./backend/cmd/pi-web-server --mock",
    "backend:test": "go test ./...",
    "backend:test:coverage": "go test ./... -coverprofile=/tmp/piweb-cover.out -covermode=count >/tmp/piweb-go-test.log && go tool cover -func=/tmp/piweb-cover.out | tail -1 | grep '100.0%'",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run test && bun run backend:test && bun run build && bun run build-storybook"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.5",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "astro": "6.3.3",
    "markdown-it": "^14.1.1",
    "react": "^19.2.6",
    "react-arborist": "^3.7.0",
    "react-dom": "^19.2.6",
    "shiki": "4.0.2",
    "virtual-scroller": "^1.16.4"
  },
  "devDependencies": {
    "@storybook-astro/framework": "1.2.0",
    "@storybook/addon-docs": "10.4.0",
    "@storybook/builder-vite": "10.4.0",
    "@testing-library/jest-dom": "6.9.1",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "jsdom": "29.1.1",
    "storybook": "10.4.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
